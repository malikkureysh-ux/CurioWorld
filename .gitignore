# --- Secrets (CRITICAL) ---
# Never commit credentials, API keys, tokens, etc.
.env
.env.local
.env.*.local
*.pem
*.key
*.secret
secrets/
.roblox-token
.roblox-api-key

# --- Logs / Runtime ---
*.log
logs/
*.pid
*.seed
*.pid.lock

# --- Node / npm (Phase 3+) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python (Blender Scripts) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.tox/
.coverage

# --- Roblox Studio Local Cache ---
RobloxStudioBeta/
Roblox/
