screenshot-auto*.png

# --- Tooling artifacts ---
dist/
build/
.cache/
.tmp/
.turbo/
.parcel-cache/

# --- Test / Coverage outputs ---
coverage/
*.lcov
.nyc_output/

# --- Local-only state (NOT the workspace state/, just in case) ---
# state/ is workspace state, NOT gitignored — it's the team's daily log

# --- Generated by Phase 3+ ---
# Open Cloud deploy configs (with secrets)
.opencloud.yaml
opencloud.local.json

# --- OS temp ---
~$*
*.tmp
*.swp
*.swo